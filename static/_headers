# Whole /private/ section: noindex (covers the section index + any future tool
# page). The meet-recorder block below adds its page-specific headers on top.
/private/*
  X-Robots-Tag: noindex, nofollow

/private/tools/meet-recorder/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store
  Permissions-Policy: microphone=(self), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self' blob:; connect-src 'self'; frame-ancestors 'none'; form-action 'self'; base-uri 'self'

# Thanks page (issue #43): thin confirmation page, keep it out of the index.
/community/asians-gingers-in-tech/thanks/*
  X-Robots-Tag: noindex, nofollow

# Turnstile (challenges.cloudflare.com) is allowed site-wide in the /* CSP below,
# for the widget on the community "Get featured" form. Cloudflare Pages JOINS
# same-name headers across path rules rather than replacing them, so a per-path
# CSP block cannot ADD a source the root policy lacks: the two policies are sent
# as two CSP headers and the browser enforces their intersection, dropping the
# wider source. The root policy therefore carries challenges.cloudflare.com; it is
# inert on pages with no cf-turnstile widget.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), geolocation=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' https://static.cloudflareinsights.com https://challenges.cloudflare.com; connect-src 'self' https://cloudflareinsights.com https://challenges.cloudflare.com; frame-src https://www.youtube-nocookie.com https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
