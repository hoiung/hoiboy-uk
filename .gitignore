# Environment files
.env
.env.*
!.env.example

# Hugo
public/
resources/
.hugo_build.lock

# Legacy import staging (raw exports, not committed)
legacy/

# Legacy-import per-post logs: leak local absolute FS paths, never publish
# (removed from the repo in #33 — git history retains them; gitignored so the
# import pipeline cannot re-add them)
docs/import-logs/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Node (only if any tooling needs it)
node_modules/

# Python (import scripts)
__pycache__/
*.pyc
.venv/

# Code review graph (local AST index, regenerable)
.code-review-graph/

# AGIT member-submission PII records + Gmail OAuth credentials are owned by the
# private agit-ops back-office and live at $HOME-external paths (~/.agit-records,
# ~/.agit-secrets). This public repo no longer writes them; these guards remain as
# a belt-and-suspenders so member PII / credentials can never be committed here.
.agit-records/
.agit-secrets/
